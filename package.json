{
	"name": "@liiift-studio/opszstepper",
	"version": "1.0.16",
	"description": "Multi-cut optical family hot-swap by font-size — automatically applies Micro, Text, or Display cuts based on the element's computed font-size",
	"type": "module",
	"main": "dist/index.cjs",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build",
		"test": "vitest run",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run test && npm run build"
	},
	"peerDependencies": {
		"react": ">=17",
		"react-dom": ">=17"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"happy-dom": "^20.10.6",
		"next": "16.2.2",
		"react": "^19.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^3.0.0"
	},
	"keywords": [
		"typography",
		"web-typography",
		"frontend",
		"liiift-studio",
		"optical-size",
		"font-family",
		"opsz",
		"optical-sizing",
		"font-swap",
		"fluid-type",
		"multi-cut",
		"responsive-type",
		"responsive-design",
		"typographic",
		"zero-dependencies",
		"react",
		"typescript",
		"css"
	],
	"author": "Quinn Keaveney <quinn@liiift.studio>",
	"license": "MIT",
	"homepage": "https://opszstepper.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Liiift-Studio/OpszStepper.git"
	},
	"bugs": {
		"url": "https://github.com/Liiift-Studio/OpszStepper/issues"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	}
}
